# Postgres connection string. Get it from Supabase:
#   Project → Settings → Database → Connection string → "Transaction pooler"
# (URI form). The transaction pooler is the right one for serverless/Vercel.
#
# Example shape (yours will differ):
#   DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
#
# Copy this file to .env (gitignored) and fill it in for local dev. On Vercel,
# set DATABASE_URL as a Project Environment Variable instead.
DATABASE_URL=

# Optional: max pool size (defaults to 5).
# PGMAX=5

# REQUIRED for sign-in: secret that signs session cookies. Generate one with
#   openssl rand -base64 32
# Rotating it invalidates all existing staff sessions (they just sign in again).
# Set it in .env locally and as an env var on Vercel.
AUTH_SECRET=

# Optional: session lifetime in seconds (default 43200 = 12h).
# SESSION_TTL_SECONDS=43200

# Starter staff accounts, seeded on first boot (idempotent; survive demo reset).
# CHANGE THESE before any real deployment — at minimum the admin password.
# SEED_ADMIN_EMAIL=admin@valet.local
# SEED_ADMIN_PASSWORD=admin1234
# SEED_DRIVER_EMAIL=driver@valet.local
# SEED_DRIVER_PASSWORD=driver1234
# SEED_WAREHOUSE_EMAIL=warehouse@valet.local
# SEED_WAREHOUSE_PASSWORD=warehouse1234
